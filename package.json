{
  "name": "wonderworld-chat",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "^1.3.14",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "format": "prettier --write .",
    "prepare": "husky",
    "typecheck": "cd packages/client && bunx tsc -b && cd ../server && bunx tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  },
  "workspaces": [
    "packages/*"
  ]
}
